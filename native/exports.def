EXPORTS
    addD3DOutputSlot
    addPreloadScriptToWebView
    addScriptMessageHandlerWithReply
    callAsyncJavaScript
    clipboardAvailableFormats
    clipboardClear
    clipboardReadImage
    clipboardReadText
